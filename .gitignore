# BinIt PWA .gitignore

# ============================================
# Sensitive Data (Security)
# ============================================
.env
.env.*
*.key
*.pem
secrets.json
config.local.*

# ============================================
# Local Development Files
# ============================================
node_modules/
npm-debug.log*
*.log
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# Build Outputs
# ============================================
dist/
build/

# ============================================
# IDE/Editor
# ============================================
.vscode/
.idea/

# ============================================
# Miscellaneous
# ============================================
SPEC.md
wiki/